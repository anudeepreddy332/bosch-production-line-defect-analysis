# =========================
# 🧠 Python / Cache
# =========================
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# =========================
# 🧪 Environments
# =========================
.env
.venv/
venv/
*.egg-info/

# =========================
# 💻 OS / IDE
# =========================
.DS_Store
.idea/
.vscode/

# =========================
# 📊 Data (DO NOT PUSH RAW)
# =========================
data/raw/
# Ignore processed parquet, but TRACK the provenance manifest so data state is self-documenting.
data/processed/*
!data/processed/PROVENANCE.json
data/models/
data/artifacts/

# Keep ONLY essential feature artifacts (optional override)
# Comment this out if you WANT to track features
data/features/*.parquet
data/features/*.pkl
data/features/*.json

# =========================
# 📈 Outputs (EXPERIMENTAL)
# =========================
outputs/*.csv
outputs/*.parquet

# Monitoring artifacts
outputs/**/daily_drift_report.json
outputs/**/reference.parquet
outputs/**/current.parquet

# Simulation artifacts
outputs/**/batch_simulation_state.json
outputs/**/batch_stream_log.csv

# Track 3 production batch inference artifacts (generated, append-only, per-batch)
outputs/production/

# Model artifacts
outputs/models/
models/*.pkl
# =========================
# 📜 Logs
# =========================
logs/
**/logs/
*.log

src/_deprecated/

# Agent prompts
agent.md
system_design.md
execution_rules.md
tasks.md